---
interface Article {
  url: string;
  title: string;
  created: string;
  image: {
    url: string;
    alt: string;
    width: number | null;
    height: number | null;
  } | null;
}

interface Props {
  articles: Article[];
}

const { articles } = Astro.props;
const formatDate = (value: string) =>
  new Intl.DateTimeFormat('el-GR', {
    day: 'numeric',
    month: 'short',
    year: 'numeric',
  }).format(new Date(value));
---

<section class="latest-articles" aria-labelledby="latest-articles-title">
  <p class="eyebrow">Από enterlife</p>
  <h2 id="latest-articles-title">Τελευταία άρθρα</h2>
  <div class="latest-articles__list">
    {
      articles.slice(0, 4).map((article) => (
        <article class="latest-article">
          <a
            class="latest-article__media"
            href={article.url}
            aria-label={`Διαβάστε: ${article.title}`}
          >
            {article.image ? (
              <img
                src={article.image.url}
                alt={article.image.alt}
                width={article.image.width}
                height={article.image.height}
                loading="lazy"
              />
            ) : (
              <span aria-hidden="true" />
            )}
          </a>
          <div>
            <time datetime={article.created}>{formatDate(article.created)}</time>
            <h3><a href={article.url}>{article.title}</a></h3>
          </div>
        </article>
      ))
    }
  </div>
</section>

<style>
  .latest-articles > .eyebrow {
    margin-bottom: 0.45rem;
    color: var(--blue-deep);
  }

  .latest-articles > h2 {
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--line);
    font-size: 1.85rem;
  }

  .latest-articles__list {
    display: grid;
    gap: 1.15rem;
  }

  .latest-article {
    display: grid;
    align-items: start;
    gap: 0.85rem;
    grid-template-columns: 4.75rem minmax(0, 1fr);
  }

  .latest-article__media {
    display: block;
    aspect-ratio: 1;
    overflow: hidden;
    background: linear-gradient(145deg, #e3eeee, var(--paper-soft));
  }

  .latest-article__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 240ms ease;
  }

  .latest-article:hover .latest-article__media img {
    transform: scale(1.05);
  }

  time {
    display: block;
    margin-bottom: 0.25rem;
    color: var(--muted);
    font-size: 0.65rem;
  }

  h3 {
    margin: 0;
    font-size: 1rem;
    line-height: 1.25;
  }

  h3 a {
    text-decoration: none;
  }

  @media (max-width: 62rem) {
    .latest-articles__list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 38rem) {
    .latest-articles__list {
      grid-template-columns: 1fr;
    }
  }
</style>
