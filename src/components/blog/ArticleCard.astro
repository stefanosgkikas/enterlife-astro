---
interface Props {
  article: {
    url: string;
    title: string;
    created: string;
    excerpt: string;
    image: {
      url: string;
      alt: string;
      width: number | null;
      height: number | null;
    } | null;
    author: { name: string; slug?: string; pictureUrl?: string | null };
    tags: string[];
    categories?: Array<{ name: string; slug: string; color?: string | null }>;
    category: string | null;
    categorySlug: string | null;
  };
}

const { article } = Astro.props;
const articleCategories = article.categories?.length
  ? article.categories
  : article.category && article.categorySlug
    ? [{ name: article.category, slug: article.categorySlug }]
    : [];
const publishedAt = new Intl.DateTimeFormat('el-GR', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
}).format(new Date(article.created));
const searchText = [
  article.title,
  article.excerpt,
  ...articleCategories.map((category) => category.name),
  article.author?.name,
  ...(article.tags ?? []),
]
  .filter(Boolean)
  .join(' ')
  .toLocaleLowerCase('el-GR');
const authorInitial = article.author?.name?.trim()?.[0]?.toLocaleUpperCase('el-GR') ?? 'E';
---

<article
  class="article-card"
  data-blog-card
  data-category={article.categorySlug}
  data-categories={articleCategories.map((category) => category.slug).join('|')}
  data-url={article.url}
  data-search={searchText}
>
  <a
    class="article-card__media"
    href={article.url}
    aria-label={`Διαβάστε: ${article.title}`}
  >
    {
      article.image ? (
        <img
          src={article.image.url}
          alt={article.image.alt}
          width={article.image.width}
          height={article.image.height}
          loading="lazy"
        />
      ) : (
        <span class="article-card__fallback" aria-hidden="true">
          <svg viewBox="0 0 320 200">
            <path d="M0 190 83 95l49 50 43-47 145 92Z" />
            <circle cx="245" cy="55" r="22" />
          </svg>
        </span>
      )
    }
  </a>

  <div class="article-card__content">
    {
      articleCategories.length > 0 && (
        <div class="article-card__categories" aria-label="Κατηγορίες άρθρου">
          {articleCategories.map((category) => (
            <a
              class="article-card__category"
              href={`/blog/category/${category.slug}`}
              style={category.color ? `--article-card-category-background: ${category.color};` : undefined}
            >
              {category.name}
            </a>
          ))}
        </div>
      )
    }
    {
      article.tags.length > 0 && (
        <div class="article-card__tags" aria-label="Ετικέτες άρθρου">
          {article.tags.map((tag) => (
            <p class="article-card__tag">{tag}</p>
          ))}
        </div>
      )
    }
    <h2><a href={article.url}>{article.title}</a></h2>
    <div class="article-card__meta">
      <span class="article-card__author">
        {
          article.author.pictureUrl ? (
            <img
              class="article-card__author-avatar"
              src={article.author.pictureUrl}
              alt=""
              width="28"
              height="28"
              loading="lazy"
            />
          ) : (
            <span class="article-card__author-avatar article-card__author-avatar--fallback" aria-hidden="true">
              {authorInitial}
            </span>
          )
        }
        {
          article.author.slug ? (
            <a class="article-card__author-name" href={`/authors/${article.author.slug}`}>
              {article.author.name}
            </a>
          ) : (
            <span class="article-card__author-name">{article.author.name}</span>
          )
        }
      </span>
      <span aria-hidden="true">·</span>
      <time datetime={article.created}>{publishedAt}</time>
    </div>
    <p class="article-card__excerpt">{article.excerpt}</p>
    <a class="text-link article-card__link" href={article.url}>
      Διαβάστε το άρθρο
    </a>
  </div>
</article>

<style>
  .article-card {
    display: flex;
    min-width: 0;
    flex-direction: column;
    border: 1px solid var(--line);
    background: var(--white);
    box-shadow: 0 0.6rem 2rem rgb(38 63 72 / 0.035);
    transition:
      border-color 220ms ease,
      box-shadow 220ms ease,
      transform 220ms ease;
  }

  .article-card:hover {
    border-color: rgb(127 174 192 / 0.65);
    box-shadow: 0 1.25rem 3rem rgb(38 63 72 / 0.09);
    transform: translateY(-0.35rem);
  }

  .article-card__media {
    display: block;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: var(--paper-soft);
  }

  .article-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 600ms cubic-bezier(0.2, 0.75, 0.2, 1);
  }

  .article-card:hover .article-card__media img {
    transform: scale(1.035);
  }

  .article-card__fallback {
    display: grid;
    width: 100%;
    height: 100%;
    place-items: center;
    background: linear-gradient(145deg, #edf3f3, #f7f3ef);
  }

  .article-card__fallback svg {
    width: 72%;
    fill: rgb(127 174 192 / 0.22);
  }

  .article-card__content {
    display: flex;
    flex: 1;
    flex-direction: column;
    padding: clamp(1.35rem, 2.4vw, 2rem);
  }

  .article-card__category {
    display: inline-block;
    padding: 0.2rem 0.6rem;
    border-radius: 3px;
    font-size: 0.75rem;
    font-weight: 750;
    letter-spacing: 0.08em;
    text-decoration: none;
    align-items: center;
		justify-content: center;
		padding-inline: 0,5rem;
    border: 1px solid var(--article-card-category-background, var(--ink-deep));
    border-radius: 5px;
    background: var(--article-card-category-background, var(--ink-deep));
    color: var(--white);
  }

  .article-card__categories {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-bottom: 0.5rem;
  }

  .article-card__category:hover {
    background: var(--article-card-category-background, var(--blue-deep));
  }

  .article-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 0.65rem;
    margin-bottom: 0.75rem;
  }

  .article-card__tag {
    margin: 0;
    color: var(--blue-deep);
    font-size: 0.62rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  h2 {
    margin-bottom: 0.8rem;
    font-size: clamp(1.2rem, 2vw, 1.6rem);
    line-height: 1.25;
  }

  h2 a {
    text-decoration: none;
  }

  .article-card__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.45rem;
    margin-bottom: 1rem;
    color: var(--black);
    font-size: 0.85rem;
  }

  .article-card__author {
    display: flex;
    min-width: 0;
    align-items: center;
    gap: 0.45rem;
  }

  .article-card__author-avatar {
    width: 2.5rem;
    height: 2.5rem;
    flex: 0 0 auto;
    border: 1px solid rgb(127 174 192 / 0.28);
    border-radius: 50%;
    background: var(--paper-soft);
    object-fit: cover;
  }

  .article-card__author-avatar--fallback {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--blue-deep);
    font-size: 0.72rem;
    font-weight: 800;
    line-height: 1;
  }

  .article-card__author-name {
    min-width: 0;
    text-decoration: none;
  }
   .article-card__author-name:hover {
      text-decoration: underline;
  }

  .article-card__excerpt {
    display: -webkit-box;
    margin-bottom: 1.5rem;
    overflow: hidden;
    color: var(--black);
    font-size: 0.95rem;
    line-height: 1.6;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
  }

  .article-card__link {
    align-self: flex-start;
    margin-top: auto;
  }

  @media (max-width: 48rem) {
    .article-card__content {
      padding: 1.25rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .article-card,
    .article-card__media img {
      transform: none;
    }
  }
</style>
