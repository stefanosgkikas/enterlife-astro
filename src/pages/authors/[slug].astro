---
import ArticleCard from '../../components/blog/ArticleCard.astro';
import Layout from '../../layouts/Layout.astro';
import { deriveBlogCategories, fetchAuthors } from '../../lib/drupal.mjs';

export async function getStaticPaths() {
	const authors = await fetchAuthors();
	const navigationCategories = deriveBlogCategories(authors.flatMap((entry) => entry.articles));

	return authors.map((author) => ({
		params: { slug: author.slug },
		props: {
			author,
			navigationCategories,
		},
	}));
}

const { author, navigationCategories } = Astro.props;
const publishedAt = new Intl.DateTimeFormat('el-GR', {
	day: 'numeric',
	month: 'long',
	year: 'numeric',
}).format(new Date(author.articles[0]?.created));
---

<Layout
	title={`${author.name} | Συγγραφείς | Enterlife`}
	description={`Άρθρα από τον/την ${author.name} στο Enterlife.`}
	navigationCategories={navigationCategories}
>
	<article class="single-author">
		<header class="author-hero">
			<div class="author-hero__copy container">
				<a class="author-hero__back" href="/authors/">Όλοι οι συγγραφείς</a>
				<div class="author-hero__profile">
					<div class="author-hero__avatar">
						{author.pictureUrl ? (
							<img
								src={author.pictureUrl}
								alt={author.name}
								width="200"
								height="200"
								loading="eager"
							/>
						) : (
							<span class="author-hero__initials" aria-hidden="true">
								{author.name.charAt(0)}
							</span>
						)}
					</div>
				<div class="author-hero__details">
					<h1>{author.name}</h1>
					{author.profession && (
						<p class="author-hero__profession">{author.profession}</p>
					)}
					<div class="author-hero__meta">
						<span>{author.articleCount} {author.articleCount === 1 ? 'άρθρο' : 'άρθρα'}</span>
						{author.articles[0] && (
							<>
								<span aria-hidden="true">·</span>
								<time datetime={author.articles[0].created}>
									Τελευταίο άρθρο: {publishedAt}
								</time>
							</>
						)}
					</div>
					{(author.email || author.cv?.url) && (
						<div class="author-hero__actions">
							{author.email && (
								<p class="author-hero__action">
									<svg aria-hidden="true" viewBox="0 0 24 24" width="16" height="16">
										<rect x="3" y="5" width="18" height="14" rx="1" fill="none" stroke="currentColor" stroke-width="1.5"/>
										<path d="m4 7 8 6 8-6" fill="none" stroke="currentColor" stroke-width="1.5"/>
									</svg>
									<a href={`mailto:${author.email}`}>{author.email}</a>
								</p>
							)}
							{author.cv?.url && (
								<p class="author-hero__action" data-author-cv>
									<svg
										aria-label="PDF"
										role="img"
										viewBox="0 0 24 24"
										width="16"
										height="16"
									>
										<path
											d="M6 2.75h8l4 4V21.25H6zM14 2.75v4h4"
											fill="none"
											stroke="currentColor"
											stroke-width="1.5"
											stroke-linejoin="round"
										/>
										<path
											d="M8.25 16.5v-4h1.4a1.25 1.25 0 0 1 0 2.5h-1.4m4.2 1.5v-4h1.05a2 2 0 0 1 0 4zm4.3 0v-4H20"
											fill="none"
											stroke="currentColor"
											stroke-width="1.25"
											stroke-linecap="round"
											stroke-linejoin="round"
										/>
									</svg>
									<a
										href={author.cv.url}
										target="_blank"
										rel="noopener noreferrer"
										type={author.cv.mimeType}
									>
										Πλήρες βιογραφικό
									</a>
								</p>
							)}
						</div>
					)}
					{author.shortBio && (
						<p class="author-hero__short-bio">{author.shortBio}</p>
					)}
				</div>
				</div>
			</div>
		</header>

		<section class="author-articles container" aria-label={`Άρθρα του/της ${author.name}`}>
			{
				author.articles.length > 0 ? (
					<div class="author-articles__grid">
						{author.articles.map((article) => (
							<ArticleCard article={article} />
						))}
					</div>
				) : (
					<p class="author-articles__empty">Δεν υπάρχουν δημοσιευμένα άρθρα ακόμη.</p>
				)
			}
		</section>
	</article>
</Layout>

<style>
	.author-hero {
		position: relative;
		overflow: hidden;
		border-block: 1px solid var(--line);
		background:
			radial-gradient(circle at 72% 28%, rgb(169 212 225 / 0.4), transparent 22rem),
			linear-gradient(145deg, var(--paper-soft), var(--paper));
	}

	.author-hero__copy {
		position: relative;
		z-index: 1;
		padding-block: clamp(3rem, 6vw, 5rem);
	}

	.author-hero__back {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		margin-bottom: 2.5rem;
		color: var(--blue-deep);
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-decoration: none;
		text-transform: uppercase;
	}

	.author-hero__back::before {
		display: inline-block;
		width: 0.6rem;
		height: 0.6rem;
		border-bottom: 2px solid currentColor;
		border-left: 2px solid currentColor;
		content: "";
		transform: rotate(45deg);
	}

	.author-hero__profile {
		display: flex;
		align-items: flex-start;
		gap: clamp(1.5rem, 3vw, 2.5rem);
	}

	.author-hero__details {
		flex: 1;
		min-width: 0;
		width: 100%;
	}

	.author-hero__avatar {
		flex-shrink: 0;
		width: clamp(5.5rem, 10vw, 8rem);
		height: clamp(5.5rem, 10vw, 8rem);
		border-radius: 50%;
		overflow: hidden;
		background: linear-gradient(145deg, #edf3f3, #f7f3ef);
	}

	.author-hero__avatar img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.author-hero__initials {
		display: grid;
		width: 100%;
		height: 100%;
		color: var(--muted);
		font-family: var(--display);
		font-size: clamp(2rem, 4vw, 3.2rem);
		place-items: center;
	}

	.author-hero h1 {
		margin-bottom: 0.25rem;
		font-size: clamp(2.2rem, 5vw, 4rem);
	}

	.author-hero__profession {
		margin-bottom: 0.75rem;
		color: var(--blue-deep);
		font-size: 0.85rem;
		font-weight: 600;
	}

	.author-hero__meta {
		display: flex;
		flex-wrap: wrap;
		gap: 0.45rem;
		margin-bottom: 0.65rem;
		color: var(--muted);
		font-size: 0.78rem;
	}

	.author-hero__actions {
		display: flex;
		align-items: center;
		flex-wrap: nowrap;
		gap: 0.75rem 1.5rem;
		margin-top: 0.65rem;
	}

	.author-hero__action {
		display: flex;
		min-width: 0;
		align-items: center;
		gap: 0.45rem;
		margin: 0;
		font-size: 0.82rem;
	}

	.author-hero__action svg {
		flex-shrink: 0;
		color: var(--blue-deep);
	}

	.author-hero__action a {
		color: var(--muted);
		text-decoration: none;
		overflow-wrap: anywhere;
	}

	.author-hero__action a:hover {
		color: var(--blue-deep);
		text-decoration: underline;
	}

	.author-hero__short-bio {
		margin-top: 0.75rem;
		width: 100%;
		color: var(--muted);
		font-size: 0.92rem;
		line-height: 1.6;
	}

	.author-articles {
		padding-block: clamp(4rem, 8vw, 8rem);
	}

	.author-articles__grid {
		display: grid;
		align-items: stretch;
		gap: clamp(1.25rem, 2.5vw, 2.25rem);
		grid-template-columns: repeat(3, minmax(0, 1fr));
	}

	.author-articles__empty {
		padding: 4rem;
		border: 1px solid var(--line);
		background: var(--white);
		text-align: center;
	}

	@media (max-width: 62rem) {
		.author-articles__grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 48rem) {
		.author-hero__profile {
			flex-direction: column;
			align-items: center;
			text-align: center;
		}

		.author-hero__meta {
			justify-content: center;
		}

		.author-hero__actions {
			align-items: center;
			flex-direction: column;
			gap: 0.5rem;
		}

		.author-articles__grid {
			grid-template-columns: 1fr;
		}
	}
</style>
