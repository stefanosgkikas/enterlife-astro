# Build-time only. Keep the localhost value in .env for local development.
# In Cloudflare Pages set this to the public Drupal origin, for example
# https://admin.enterlife.gr. Do not prefix it with PUBLIC_.
DRUPAL_BASE_URL=http://admin.enterlife.localhost

# Used to create absolute social-share links in the generated pages. In the
# Cloudflare Pages production environment use the public site URL.
PUBLIC_SITE_URL=http://enterlife.localhost
